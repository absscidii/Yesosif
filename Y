-- Variables
local infiniteOn = false
local knockbackOn = false
local immortalOn = false

local function removeBeam()
    local args = { "GetToken", "CombatFunction", "RemoveBeam" }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("CombatRemote"):FireServer(unpack(args))
end

-- Infinite Beam (Energy 0 + 100 Billion Damage + Infinite Duration)
local function fireInfiniteBeam()
    local args = {
        "GetToken", "CombatFunction", "CreateBeam",
        {
            Knockback = { FaceTarget = false, Velocity = 0, YVelocity = 0, Duration = 0.2 },
            Name = "Atomic Power Red",
            CanMove = true,
            Cooldown = 30,
            ForwardData = { YVelocity = 0, Duration = math.huge, Update = true, Velocity = 0 },
            Energy = 0,
            Damage = NumberRange.new(100000000000, 100000000000)  -- 100 Billion
        },
        "RadiumBeam"
    }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("CombatRemote"):FireServer(unpack(args))
end

-- Strong Knockback Beam
local function fireKnockbackBeam()
    local args = {
        "GetToken", "CombatFunction", "CreateBeam",
        {
            Knockback = { FaceTarget = false, Velocity = 150, YVelocity = 80, Duration = 1.5 },
            Name = "Atomic Power Red",
            CanMove = true,
