    immortalOn = not immortalOn
    if immortalOn then
        toggle3.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        toggle3.Text = "Immortal Player ✓"
        fireImmortalBeam()
    else
        toggle3.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        toggle3.Text = "Immortal Player (Godmode)"
        removeBeam()
    end
    status.Text = (infiniteOn or knockbackOn or immortalOn) and "Active" or "All OFF"
end)

-- Cleanup
screenGui.Destroying:Connect(function()
    if infiniteOn or knockbackOn or immortalOn then
        removeBeam()
    end
end)

