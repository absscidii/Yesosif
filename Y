-- Unified Fire Function using "Atomic"
local function fireAtomic(damage, energy)
    local args = {
        "GetToken",
        "CombatFunction",
        "CreateBeam",
        {
            Knockback = {
                FaceTarget = false,
                Velocity = 0,
                YVelocity = 0,
                Duration = 0.2
            },
            Name = "Atomic",                    -- Normal Atomic name
            CanMove = true,
            Cooldown = 25,
            Energy = energy,
            ForwardData = {
                YVelocity = 0,
                Duration = math.huge,
                Update = true,
                Velocity = 0
            },
            Damage = NumberRange.new(damage, damage)
        }
    }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("CombatRemote"):FireServer(unpack(args))
end

