-- Immortal Player (math.huge damage - Godmode beam)
local function fireImmortalBeam()
    local args = {
        "GetToken", "CombatFunction", "CreateBeam",
        {
            Knockback = { FaceTarget = false, Velocity = 0, YVelocity = 0, Duration = 0.2 },
            Name = "Atomic Power Red",
            CanMove = true,
            Cooldown = 30,
            ForwardData = { YVelocity = 0, Duration = math.huge, Update = true, Velocity = 0 },
            Energy = 0,
            Damage = NumberRange.new(math.huge, math.huge)
        },
        "RadiumBeam"
    }
    game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("CombatRemote"):FireServer(unpack(args))
end

-- Toggle 1: Infinite Beam (100B)
toggle1.MouseButton1Click:Connect(function()
    infiniteOn = not infiniteOn
    if infiniteOn then
        toggle1.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        toggle1.Text = "Infinite Beam (100B) ✓"
        fireInfiniteBeam()
    else
        toggle1.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        toggle1.Text = "Infinite Beam (100B DMG)"
        removeBeam()
    end
    status.Text = (infiniteOn or knockbackOn or immortalOn) and "Active" or "All OFF"
end)

-- Toggle 2: Strong Knockback
toggle2.MouseButton1Click:Connect(function()
    knockbackOn = not knockbackOn
    if knockbackOn then
        toggle2.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        toggle2.Text = "Strong Knockback ✓"
        fireKnockbackBeam()
    else
        toggle2.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        toggle2.Text = "Strong Knockback (DMG 2)"
        removeBeam()
    end
    status.Text = (infiniteOn or knockbackOn or immortalOn) and "Active" or "All OFF"
end)

-- Toggle 3: Immortal Player (Godmode)
